#compdef pkg
# zsh completion for pkg (pacman wrapper)
#
# Install:
#   - Copy this file (named `_pkg`) into a directory on your $fpath, e.g.
#       /usr/share/zsh/site-functions/_pkg
#     or in your ~/.zshrc add:
#       fpath=(/path/to/completions $fpath)
#       autoload -Uz compinit && compinit

_pkg() {
  local context state state_descr line
  typeset -A opt_args

  local -a commands
  commands=(
    'install:Install packages (pacman -S)'
    'reinstall:Reinstall packages (pacman -S)'
    'add:Install from a local package file (pacman -U)'
    'fetch:Download but do not install (pacman -Sw)'
    'uninstall:Remove packages and unused deps (pacman -Rs)'
    'remove:Alias for uninstall'
    'delete:Alias for uninstall'
    'purge:Remove packages, deps, config (pacman -Rns)'
    'update:Refresh package database (pacman -Sy)'
    'upgrade:Upgrade all installed packages (pacman -Syu)'
    'dist-upgrade:Alias for upgrade'
    'full-upgrade:Alias for upgrade'
    'search:Search remote packages (pacman -Ss)'
    'show:Show info about a package (pacman -Si / -Qi)'
    'info:Alias for show'
    'list:List installed packages (pacman -Q)'
    'list-installed:Alias for list'
    'list-explicit:List explicitly-installed packages (pacman -Qe)'
    'files:List files owned by a package (pacman -Ql / -Fl)'
    'owns:Find which package owns a file (pacman -Qo)'
    'which:Alias for owns'
    'provides:Find package providing a file (pacman -F)'
    'orphans:List unused dependencies (pacman -Qdt)'
    'version:List packages with updates (pacman -Qu)'
    'check:Verify installed package files (pacman -Qk)'
    'autoremove:Remove unused dependencies'
    'clean:Remove cached packages (pacman -Sc)'
    'help:Show help'
  )

  _arguments -C \
    '1: :->command' \
    '*:: :->args'

  case $state in
    command)
      _describe -t commands 'pkg command' commands
      ;;
    args)
      case $words[1] in
        install|reinstall|fetch|search|show|info|files|version|check)
          local -a all_pkgs
          all_pkgs=( ${(f)"$(pacman -Slq 2>/dev/null)"} )
          _describe -t packages 'package' all_pkgs
          ;;
        uninstall|remove|delete|purge)
          local -a installed
          installed=( ${(f)"$(pacman -Qq 2>/dev/null)"} )
          _describe -t packages 'installed package' installed
          ;;
        add)
          _files -g '*.pkg.tar.(zst|xz|gz)'
          ;;
        owns|which|provides)
          _files
          ;;
        *)
          ;;
      esac
      ;;
  esac
}

_pkg "$@"
